# Groq API Key (Primary)
GROQ_API_KEY=your_groq_api_key_here

# Deepgram API Key (Fallback)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Allowed Origin (Frontend URL)
# For local dev: http://localhost:5500 or similar
# For production: https://reelscribe.vercel.app
ALLOWED_ORIGIN=*

# Rate Limiting
RATELIMIT_ENABLED=True

# File Sizes
MAX_UPLOAD_MB=50
